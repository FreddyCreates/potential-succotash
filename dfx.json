{
  "version": 1,
  "dfx": "0.22.0",
  "canisters": {
    "vigil_frontend": {
      "type": "assets",
      "source": ["."],
      "workspace": "vigil_frontend",
      "build": [],
      "declarations": {
        "output": "src/declarations/vigil_frontend",
        "bindings": ["js"]
