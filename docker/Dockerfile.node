# Dockerfile.node — Node.js environment for Workers/Extensions
FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json ./
RUN npm install --prefer-offline 2>/dev/null || true

COPY . .

EXPOSE 8787

CMD ["npm", "run", "build"]
