{
  "manifest_version": 3,
  "name": "Edge Runner",
  "version": "1.0.0",
  "description": "AI User Experience \u2014 Offline local AI inference with zero cloud, zero latency, full privacy on your device",
  "permissions": [
    "activeTab",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "minimum_chrome_version": "110"
}
