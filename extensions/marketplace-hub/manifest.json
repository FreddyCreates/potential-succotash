{
  "manifest_version": 3,
  "name": "Marketplace Hub",
  "version": "1.0.0",
  "description": "AI Tool Marketplace Intelligence — Discover, invoke, and explore 24 callable organism tools across 4 families with natural language",
  "permissions": ["activeTab", "storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "110"
}
