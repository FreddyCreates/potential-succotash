{
  "manifest_version": 3,
  "name": "Voice Forge",
  "version": "1.0.0",
  "description": "AI User Experience \u2014 Speak and it listens, ask it to speak and it generates voice, ask for music and it composes",
  "permissions": [
    "activeTab",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "minimum_chrome_version": "110"
}
