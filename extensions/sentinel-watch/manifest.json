{
  "manifest_version": 3,
  "name": "Sentinel Watch",
  "version": "1.0.0",
  "description": "AI User Experience \u2014 Real-time phishing, malware, and social engineering detection on every page you visit",
  "permissions": [
    "activeTab",
    "webRequest",
    "webNavigation",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "minimum_chrome_version": "110"
}
