{
  "manifest_version": 3,
  "name": "Jarvis AI",
  "version": "4.0.0",
  "description": "JARVIS AI v4.0 — 40-category autonomous intelligence, 250 protocols, persistent memory, PhantomAI conversation engine, tab control, and Universal CPL WASM",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "sidePanel",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "devtools_page": "devtools.html",
  "web_accessible_resources": [
    {
      "resources": ["jarvisius-engine.wasm"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}

