{
  "manifest_version": 3,
  "name": "Sovereign Mind",
  "version": "1.0.0",
  "description": "AI User Experience — Ask anything, get fused reasoning from GPT + Claude + Gemini in one sovereign answer with phi-weighted confidence scoring",
  "permissions": ["activeTab", "storage", "identity"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "110"
}
