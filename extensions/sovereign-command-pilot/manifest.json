{
  "manifest_version": 3,
  "name": "Sovereign Command Pilot",
  "version": "1.0.0",
  "description": "AI User Experience — First-party sovereign command pilot for production workflows, planning, and execution guidance in-page.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "110",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
