{
  "manifest_version": 3,
  "name": "Social Cortex",
  "version": "1.0.0",
  "description": "AI User Experience \u2014 AI reads the social room with sentiment analysis, empathy detection, and response drafting",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "minimum_chrome_version": "110"
}
