{
  "manifest_version": 3,
  "name": "Windows File Oracle",
  "version": "1.0.0",
  "description": "File System Intelligence — Embeddings + Florence + CLIP visual and semantic file understanding for Windows",
  "platform": "windows",
  "permissions": [
    "file-system",
    "indexing",
    "thumbnails",
    "storage"
  ],
  "engine": {
    "service": "engine.js"
  },
  "interface": {
    "entry": "interface.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_windows_version": "10.0.19041"
}
