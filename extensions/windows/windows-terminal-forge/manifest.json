{
  "manifest_version": 3,
  "name": "Windows Terminal Forge",
  "version": "1.0.0",
  "description": "Terminal & PowerShell AI — Codex + DeepSeek + Phi intelligent terminal assistance for Windows Terminal",
  "platform": "windows",
  "permissions": [
    "terminal",
    "powershell",
    "clipboard",
    "process-management"
  ],
  "engine": {
    "service": "engine.js"
  },
  "interface": {
    "entry": "interface.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_windows_version": "10.0.19041"
}
