{
  "manifest_version": 3,
  "name": "Windows Notification Cortex",
  "version": "1.0.0",
  "description": "Smart Notification Intelligence — GPT + Claude + Inflection empathic notification management for Windows",
  "platform": "windows",
  "permissions": [
    "notifications",
    "action-center",
    "toast",
    "storage"
  ],
  "engine": {
    "service": "engine.js"
  },
  "interface": {
    "entry": "interface.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_windows_version": "10.0.19041"
}
