{
  "manifest_version": 3,
  "name": "Windows Copilot Hub",
  "version": "1.0.0",
  "description": "AI User Experience — Unified Windows Copilot Intelligence with GPT + Claude + Gemini + Llama multi-model fusion. Phi-weighted reasoning from your desktop to your browser.",
  "permissions": [
    "activeTab",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "110",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
