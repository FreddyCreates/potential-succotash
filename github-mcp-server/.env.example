# Copy this file to .env (or set as real environment variables) and fill in your own token.
# Never commit a real token to source control.

# GitHub personal access token. Needs at least the "repo" scope for private repos,
# or "public_repo" if you only work with public repos. Fine-grained tokens work too
# as long as they're granted Contents, Pull requests, and Metadata (read/write) on
# the target repos.
GITHUB_TOKEN=ghp_your_personal_access_token_here
